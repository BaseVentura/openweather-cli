{
  "name": "openweather-cli",
  "version": "2.0.0",
  "description": "A minimal CLI tool to get weather information from OpenWeatherMap API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "node --test dist/**/*.test.js",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "cli",
    "weather",
    "openweathermap",
    "weather-api"
  ],
  "bin": {
    "weather": "./dist/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Max Stricker",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/BaseVentura/openweather-cli"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "chalk": "^5.3.0",
    "configstore": "^8.0.0",
    "inquirer": "^9.2.12"
  },
  "devDependencies": {
    "@types/configstore": "^6.0.2",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  }
}
